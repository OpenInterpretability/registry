{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenInterpretability/registry/blob/main/schemas/interp_card.json",
  "title": "OpenInterp Interpretation Card v0.1",
  "description": "Per-feature interpretation record. Documents what a SAE feature, attention head, or circuit is interpreted as doing — with provenance for autointerp labels.",
  "type": "object",
  "required": [
    "schema_version",
    "feature_id",
    "model_target",
    "autointerp_label",
    "autointerp_provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "feature_id": {
      "type": "string",
      "description": "Unique identifier, e.g. 'qwen36-27b-papergrade-L31-f34957'"
    },
    "model_target": {
      "type": "object",
      "required": ["model_id", "layer"],
      "properties": {
        "model_id": { "type": "string" },
        "layer": { "type": "integer" },
        "sae_id": { "type": "string", "description": "If SAE feature: SAE repo ID, e.g. caiovicentino1/qwen36-27b-sae-papergrade" },
        "feature_index": { "type": "integer", "description": "Index within the SAE" },
        "head_index": { "type": "integer", "description": "For attention heads" }
      }
    },
    "autointerp_label": {
      "type": "string",
      "description": "Short human-readable label, e.g. 'end-of-thinking sentence boundary'"
    },
    "autointerp_provenance": {
      "type": "object",
      "required": ["labeler_model", "method", "date"],
      "properties": {
        "labeler_model": { "type": "string", "description": "Which LLM produced the label, e.g. 'anthropic/claude-opus-4.7'" },
        "method": { "type": "string", "enum": ["top_activating_contexts", "diff_means_logit_lens", "ablation_effect", "manual", "other"] },
        "prompt_hash": { "type": "string", "description": "SHA256 of the prompt template used for autointerp" },
        "n_contexts": { "type": "integer" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "top_activating_contexts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "activation": { "type": "number" },
          "token_position": { "type": "integer" }
        }
      },
      "description": "Top-k examples that maximally activate this feature"
    },
    "ablation_effect": {
      "type": "object",
      "description": "Effect of ablating this feature on downstream logits / outputs",
      "properties": {
        "delta_logit_top_promoted_token": { "type": "number" },
        "kl_divergence_to_baseline": { "type": "number" },
        "n_samples": { "type": "integer" }
      }
    },
    "replication_status": {
      "type": "string",
      "enum": ["single", "multiple", "none", "contradicted"],
      "description": "Has this interpretation been independently replicated?"
    },
    "causal_report_link": {
      "type": "string",
      "format": "uri",
      "description": "Link to associated causal_report.json if the feature has been tested with Six Diagnostics"
    },
    "artifact_links": {
      "type": "object",
      "properties": {
        "hf_dataset": { "type": "string", "format": "uri" },
        "neuronpedia": { "type": "string", "format": "uri" }
      }
    }
  }
}
