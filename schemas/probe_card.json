{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OpenInterpretability/registry/blob/main/schemas/probe_card.json",
  "title": "OpenInterp Probe Card v0.1",
  "description": "Documents a trained activation probe — what it claims, what controls passed, what assumptions hold, what is known to break it. Required for any probe submitted to the OpenInterp registry or claimed as causal.",
  "type": "object",
  "required": [
    "schema_version",
    "probe_id",
    "name",
    "model_target",
    "task",
    "training",
    "performance",
    "baselines",
    "license"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "probe_id": {
      "type": "string",
      "description": "Unique slug, e.g. 'fabricationguard-qwen36-27b-l31-v2'"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "author": {
      "type": "string",
      "description": "GitHub handle or ORCID"
    },
    "model_target": {
      "type": "object",
      "required": ["model_id", "layer", "position"],
      "properties": {
        "model_id": { "type": "string", "description": "HF model identifier, e.g. Qwen/Qwen3.6-27B" },
        "architecture": { "type": "string", "description": "dense / moe / hybrid-gdn / mamba / rwkv / linear-attention" },
        "layer": { "type": "integer", "minimum": 0 },
        "position": { "type": "string", "description": "where in the residual / cache the probe reads, e.g. 'pre_tool', 'turn_end', 'think_start'" },
        "d_in": { "type": "integer" }
      }
    },
    "task": {
      "type": "object",
      "required": ["target_concept", "task_type"],
      "properties": {
        "target_concept": { "type": "string", "description": "What the probe predicts, e.g. 'hallucination', 'sandbagging', 'CoT-integrity'" },
        "task_type": { "type": "string", "enum": ["binary_classification", "multiclass_classification", "regression"] },
        "label_source": { "type": "string", "description": "How ground truth was obtained: human-labeled, LLM-judge, automated, etc." }
      }
    },
    "training": {
      "type": "object",
      "required": ["n_train", "n_test"],
      "properties": {
        "n_train": { "type": "integer", "minimum": 1 },
        "n_test": { "type": "integer", "minimum": 1 },
        "class_balance": { "type": "object", "additionalProperties": { "type": "number" } },
        "splits": { "type": "string", "description": "e.g. 'random 70/15/15', 'LORO by repo', 'cross-task'" },
        "regularization": { "type": "string", "description": "e.g. 'sklearn LogisticRegression C=1.0'" }
      }
    },
    "performance": {
      "type": "object",
      "required": ["auroc", "n_eval"],
      "properties": {
        "auroc": { "type": "number", "minimum": 0, "maximum": 1 },
        "auroc_ci_95": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "f1": { "type": "number" },
        "n_eval": { "type": "integer" },
        "eval_distribution": { "type": "string", "description": "in-distribution / cross-domain / cross-model" }
      }
    },
    "baselines": {
      "type": "object",
      "description": "Mandatory anti-Goodhart baselines per the OpenInterp Six Diagnostics protocol.",
      "required": ["random_feature", "capacity_sweep", "shuffled_source"],
      "properties": {
        "random_feature": {
          "type": "object",
          "required": ["passed", "auroc"],
          "properties": {
            "passed": { "type": "boolean", "description": "Does the probe beat random-feature baseline by gap > noise?" },
            "auroc": { "type": "number", "description": "AUROC of a probe trained on randomly-drawn features at the same layer" },
            "gap": { "type": "number" }
          }
        },
        "capacity_sweep": {
          "type": "object",
          "required": ["passed", "values_tested"],
          "properties": {
            "passed": { "type": "boolean", "description": "Does the AUROC plateau across capacity K?" },
            "values_tested": { "type": "array", "items": { "type": "integer" }, "description": "List of K (capacity) values tested" },
            "auroc_at_k": { "type": "object", "additionalProperties": { "type": "number" } }
          }
        },
        "shuffled_source": {
          "type": "object",
          "description": "Required for sparse top-k targets at N_train < 200. Train probe with X shuffled, y kept.",
          "properties": {
            "passed": { "type": "boolean" },
            "recall_real": { "type": "number" },
            "recall_shuffled": { "type": "number" },
            "delta": { "type": "number" }
          }
        },
        "env_coupling": {
          "type": "object",
          "description": "Cosine similarity of probe direction between train env and inference env (e.g. fla vs sdpa attention).",
          "properties": {
            "passed": { "type": "boolean" },
            "cosine": { "type": "number" },
            "train_env": { "type": "string" },
            "inference_env": { "type": "string" },
            "refit_provided": { "type": "boolean" }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Architecture / position / data assumptions, e.g. ['residual stream', 'post-RMSNorm', 'single sample per sequence']"
    },
    "known_failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mode", "description"],
        "properties": {
          "mode": { "type": "string", "enum": ["saturation_direction", "env_coupling", "template_lock", "marginal_fit", "epiphenomenal_prior", "capacity_overparameterization", "other"] },
          "description": { "type": "string" },
          "evidence_link": { "type": "string", "format": "uri" }
        }
      }
    },
    "artifact_links": {
      "type": "object",
      "properties": {
        "hf_model": { "type": "string", "format": "uri" },
        "hf_dataset": { "type": "string", "format": "uri" },
        "code_repo": { "type": "string", "format": "uri" },
        "paper_doi": { "type": "string" },
        "zenodo_doi": { "type": "string" }
      }
    },
    "license": {
      "type": "string",
      "enum": ["apache-2.0", "mit", "cc-by-4.0", "cc0"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "probe_ids that this card supersedes (e.g. earlier version walked back)"
    }
  }
}
